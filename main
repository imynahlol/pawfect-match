    cout << "\n    PAWcessing...";
    Sleep(1500);
}

void header(){
    bluetext();
    printLine('.');
    yellowtext();
    cout << "              PAWFECT MATCH - ADOPT A PAW!\n";
    bluetext();
    printLine('.');
    resettext();
}

void welcome(){
    cout << "     Welcome, " << user << "! your fur-ever starts here :)\n";

    yellowtext();
    cout << "They've been waiting. You've been looking. Let's make it pawfect!\n";
    resettext();
    printLine('.');
    cout << endl;
}

void printLine(char line, int l){
    for(int i = 0; i < l; i++)
        cout << line;
        cout << endl;
}

void setcolor(int c){
    HANDLE h = GetStdHandle(STD_OUTPUT_HANDLE);
    SetConsoleTextAttribute(h, c);
}
void redtext(){
    setcolor(12);
}
void greentext(){
    setcolor(10);
}
void yellowtext(){
    setcolor(14);
}
void bluetext(){
    setcolor(9);
}
void purpletext(){
    setcolor(13);
}
void resettext(){
    setcolor(7);
}
